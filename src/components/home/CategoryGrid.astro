---
import { CATEGORIES } from '../../data/categories'

const COLOR_MAP = {
  blue:   { icon: 'text-blue-600 bg-blue-50',    hover: 'hover:border-blue-200' },
  pink:   { icon: 'text-pink-500 bg-pink-50',     hover: 'hover:border-pink-200' },
  red:    { icon: 'text-red-500 bg-red-50',       hover: 'hover:border-red-200' },
  purple: { icon: 'text-purple-500 bg-purple-50', hover: 'hover:border-purple-200' },
  amber:  { icon: 'text-amber-500 bg-amber-50',   hover: 'hover:border-amber-200' },
  green:  { icon: 'text-green-600 bg-green-50',   hover: 'hover:border-green-200' },
}
---

<section id="vergelijkers" class="py-16">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-medium text-ink-900 mb-6">Waar wil je op besparen?</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {CATEGORIES.map(cat => {
        const colors = COLOR_MAP[cat.color] ?? { icon: 'text-primary-500 bg-primary-50', hover: 'hover:border-primary-200' }

        if (!cat.available) {
          return (
            <div class="bg-white border border-ink-100 rounded-md p-5 opacity-50 cursor-not-allowed select-none">
              <div class="flex items-start justify-between mb-3">
                <div class="w-11 h-11 rounded-md bg-ink-100 flex items-center justify-center">
                  <span class="material-symbols-rounded text-ink-300 text-[22px]">{cat.icon}</span>
                </div>
                <span class="text-xs font-semibold bg-ink-100 text-ink-400 px-2 py-1 rounded-sm tracking-wide">
                  Binnenkort
                </span>
              </div>
              <h3 class="font-semibold text-ink-700 mb-1">{cat.name}</h3>
              <p class="text-sm text-ink-300 line-clamp-2">{cat.tagline}</p>
            </div>
          )
        }

        return (
          <a
            href={`/bespaarcheck/vergelijk/${cat.slug}/`}
            class={`bg-white border border-ink-100 rounded-md p-5 hover:shadow-md transition-all group block ${colors.hover}`}
          >
            <div class="flex items-start justify-between mb-3">
              <div class={`w-11 h-11 rounded-md flex items-center justify-center transition-colors ${colors.icon}`}>
                <span class="material-symbols-rounded text-[22px]">{cat.icon}</span>
              </div>
              <span class="material-symbols-rounded text-ink-300 text-[18px] group-hover:text-ink-600 transition-colors">arrow_forward</span>
            </div>
            <h3 class="text-lg font-semibold text-ink-900 mb-1">{cat.name}</h3>
            <p class="text-sm text-ink-500 line-clamp-2">{cat.tagline}</p>
          </a>
        )
      })}
    </div>
  </div>
</section>
